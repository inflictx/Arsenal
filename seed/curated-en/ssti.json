    {
      "subcategory": "Detection",
      "title": "Math probe (rendered)",
      "language": "text",
      "tags": ["detection"],
      "body": "7*7      → 49        evaluated = SSTI\n7*'7'    → 7777777   Jinja2 / Twig / Tornado\nWrap in the engine tag: {{7*7}}  ${7*7}  #{7*7}  <%= 7*7 %>"
    },
    {
      "subcategory": "Detection",
      "title": "Error-based probe",
      "language": "text",
      "tags": ["detection", "error-based"],
      "body": "(1/0).zxy.zxy   - if the error is visible, use its text to identify the language (see table below)"
    },
    {
      "subcategory": "Detection",
      "title": "Division-by-zero error → language",
      "language": "table",
      "tags": ["detection", "error-based"],
      "body": "ZeroDivisionError Python java.lang.ArithmeticException Java ReferenceError TypeError NodeJS Division by zero PHP divided by 0 Ruby Arithmetic operation failed Freemarker",
      "meta": {
        "kind": "table",
        "table": {
          "headers": ["Error text", "Language / engine"],
          "rows": [
            ["ZeroDivisionError", "Python"],
            ["java.lang.ArithmeticException", "Java"],
            ["ReferenceError / TypeError", "NodeJS"],
            ["Division by zero / DivisionByZeroError", "PHP"],
            ["divided by 0", "Ruby"],
            ["Arithmetic operation failed", "Freemarker (Java)"]
          ]
        }
      }
    },
    {
      "subcategory": "Detection",
      "title": "Boolean-based pairs (ok / error)",
      "language": "table",
