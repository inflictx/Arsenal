            ["300 Multiple Choices", "У запроса несколько возможных ответов, клиент выбирает один"],
            ["301 Moved Permanently", "Ресурс перемещён навсегда на URL из заголовка Location"],
            ["302 Found", "Ресурс временно находится по URL из Location (метод может смениться)"],
            ["303 See Other", "Получить ресурс по другому URI через GET"],
            ["304 Not Modified", "Кэш: ответ не изменился, использовать сохранённую версию"],
            ["305 Use Proxy", "Доступ к ресурсу через прокси из заголовка Location"],
            ["307 Temporary Redirect", "Временный редирект на URL из Location, метод сохраняется"],
            ["308 Permanent Redirect", "Постоянный редирект на URL из Location, метод сохраняется"]
          ]
        }
      }
