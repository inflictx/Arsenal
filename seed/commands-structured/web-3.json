{
  "category": "WEB",
  "catOrder": 2,
  "tools": [
    {
      "title": "nuclei",
      "subcategory": "Сканер по шаблонам уязвимостей",
      "purpose": "Быстрый сканер на базе YAML-шаблонов от ProjectDiscovery: ищет известные CVE, мисконфиги, утечки и техдетект по тысячам готовых правил.",
      "install": "go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest",
      "binary": "nuclei",
      "target": "-u {TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Цель",
          "flags": [
            { "flag": "-u", "value": "{TARGET}", "desc": "Цель: один URL или хост (можно повторять/через запятую)" },
            { "flag": "-l", "value": "targets.txt", "desc": "Файл со списком целей, по одной на строку" },
            { "flag": "-eh", "value": "host", "desc": "Исключить хосты из сканирования" },
            { "flag": "-sa", "desc": "Сканировать все IP, привязанные к DNS-записи цели" },
            { "flag": "-im", "value": "list", "desc": "Формат входа: list/burp/jsonl/yaml/openapi/swagger" }
          ]
        },
        {
          "name": "Шаблоны",
          "flags": [
            { "flag": "-t", "value": "cves/", "desc": "Запустить указанные шаблоны или каталог шаблонов" },
            { "flag": "-turl", "value": "url", "desc": "Запустить шаблоны по URL" },
            { "flag": "-w", "value": "workflow.yaml", "desc": "Запустить workflow (цепочку шаблонов)" },
            { "flag": "-as", "desc": "Авторежим: определить технологии и подобрать шаблоны автоматически" },
            { "flag": "-dast", "desc": "Включить фаззинг/DAST-шаблоны" },
            { "flag": "-nt", "desc": "Запустить только новые (свежедобавленные) шаблоны" }
          ]
        },
        {
          "name": "Фильтрация",
          "flags": [
            { "flag": "-tags", "value": "rce,sqli", "desc": "Брать только шаблоны с указанными тегами" },
            { "flag": "-etags", "value": "fuzz", "desc": "Исключить шаблоны по тегам" },
            { "flag": "-severity", "value": "high,critical", "desc": "Только уязвимости заданной критичности (info/low/medium/high/critical)" },
            { "flag": "-es", "value": "info", "desc": "Исключить по уровню критичности" },
            { "flag": "-id", "value": "CVE-2024-1234", "desc": "Запустить шаблоны с конкретными ID" },
            { "flag": "-author", "value": "pdteam", "desc": "Фильтр шаблонов по автору" }
          ]
        },
        {
          "name": "Производительность",
          "flags": [
            { "flag": "-rl", "value": "150", "desc": "Лимит запросов в секунду (по умолчанию 150)" },
            { "flag": "-c", "value": "25", "desc": "Число параллельно выполняемых шаблонов (по умолчанию 25)" },
            { "flag": "-bs", "value": "25", "desc": "Сколько хостов обрабатывать параллельно на шаблон" },
            { "flag": "-timeout", "value": "10", "desc": "Таймаут запроса в секундах" },
            { "flag": "-retries", "value": "1", "desc": "Число повторов при неудачном запросе" },
            { "flag": "-mhe", "value": "30", "desc": "Пропустить хост после N ошибок подряд" }
          ]
        },
        {
          "name": "Сеть / Запрос",
          "flags": [
            { "flag": "-H", "value": "'Header: v'", "desc": "Добавить свой HTTP-заголовок ко всем запросам" },
            { "flag": "-p", "value": "http://127.0.0.1:8080", "desc": "Проксировать трафик через HTTP/SOCKS5" },
            { "flag": "-fr", "desc": "Следовать HTTP-редиректам" },
            { "flag": "-ni", "desc": "Отключить Interactsh (OOB/out-of-band проверки)" },
            { "flag": "-iserver", "value": "url", "desc": "Свой Interactsh-сервер для OOB-взаимодействий" }
          ]
        },
        {
          "name": "Вывод / Прочее",
          "flags": [
            { "flag": "-o", "value": "out.txt", "desc": "Сохранить результаты в файл" },
            { "flag": "-j", "desc": "Вывод в формате JSONL" },
            { "flag": "-jle", "value": "out.jsonl", "desc": "Экспорт результатов в JSONL-файл (-jsonl-export)" },
            { "flag": "-me", "value": "report.md", "desc": "Экспорт результатов в Markdown (-markdown-export)" },
            { "flag": "-se", "value": "out.sarif", "desc": "Экспорт в формат SARIF" },
            { "flag": "-irr", "desc": "Включать в вывод сами запросы/ответы" },
            { "flag": "-silent", "desc": "Показывать только находки, без лишнего вывода" },
            { "flag": "-stats", "desc": "Показывать статистику хода сканирования" },
            { "flag": "-duc", "desc": "Не проверять обновления при запуске" },
            { "flag": "-ut", "desc": "Обновить базу шаблонов" }
          ]
        }
      ],
      "recipes": [
        { "cmd": "nuclei -u {TARGET} -as", "note": "Быстрый авто-скан: nuclei сам подбирает шаблоны под обнаруженный стек" },
        { "cmd": "nuclei -u {TARGET} -severity high,critical -silent", "note": "Только серьёзные находки, тихий вывод" },
        { "cmd": "nuclei -l targets.txt -tags cve -o out.txt", "note": "Прогон списка целей по CVE-шаблонам с сохранением" }
      ],
      "notes": "Перед боевым прогоном обновите шаблоны: nuclei -ut. Теги и -severity резко сужают шум."
    },
    {
      "title": "sqlmap",
      "subcategory": "Авто-эксплуатация SQL-инъекций",
      "purpose": "Эталонный инструмент для поиска и эксплуатации SQL-инъекций: от детекта точки до дампа БД, чтения файлов и шелла на сервере.",
      "install": "pipx install sqlmap  # или git clone https://github.com/sqlmapproject/sqlmap",
      "binary": "sqlmap",
      "target": "-u {TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Цель",
          "flags": [
            { "flag": "-u", "value": "{TARGET}", "desc": "Целевой URL с параметром, напр. 'http://site/vuln.php?id=1'" },
            { "flag": "-r", "value": "req.txt", "desc": "Взять HTTP-запрос целиком из файла (удобно для POST/заголовков)" },
            { "flag": "-m", "value": "urls.txt", "desc": "Скан списка целей из файла" },
            { "flag": "-g", "value": "'dork'", "desc": "Брать цели из выдачи Google по дорку" },
            { "flag": "--data", "value": "'id=1'", "desc": "POST-данные для тестирования (включает POST-режим)" },
            { "flag": "--cookie", "value": "'sid=...'", "desc": "Значение заголовка Cookie" },
            { "flag": "-p", "value": "id", "desc": "Тестировать только указанные параметры" }
          ]
        },
        {
          "name": "Детект (level / risk)",
          "flags": [
            { "flag": "--level", "value": "3", "desc": "Глубина проверки 1-5: чем выше, тем больше точек и нагрузок. 2+ добавляет тест Cookie, 3+ — тест HTTP-заголовков (User-Agent, Referer)" },
            { "flag": "--risk", "value": "2", "desc": "Риск нагрузок 1-3: 1 — безопасные, 2 — добавляет тяжёлые time-based, 3 — добавляет OR-инъекции (могут изменить/повредить данные при UPDATE)" },
            { "flag": "--string", "value": "'Welcome'", "desc": "Строка, присутствующая в ответе при True (помогает blind-детекту)" },
            { "flag": "--not-string", "value": "'error'", "desc": "Строка, которой нет в ответе при True" },
            { "flag": "--code", "value": "200", "desc": "HTTP-код, означающий True-ответ" },
            { "flag": "--smart", "desc": "Глубоко тестировать только параметры с положительной эвристикой (быстрее)" }
          ]
        },
        {
          "name": "Техники (technique)",
          "flags": [
            { "flag": "--technique", "value": "BEUSTQ", "desc": "Какие типы инъекций пробовать (по умолчанию BEUSTQ): B=boolean-blind, E=error-based, U=union, S=stacked queries (несколько запросов), T=time-blind, Q=inline-запросы" },
            { "flag": "--time-sec", "value": "5", "desc": "Задержка для time-based blind, секунд (по умолчанию 5)" },
            { "flag": "--union-cols", "value": "1-10", "desc": "Диапазон числа колонок для UNION-инъекции" },
            { "flag": "--dbms", "value": "MySQL", "desc": "Принудительно указать СУБД (MySQL/PostgreSQL/MSSQL/Oracle/SQLite...) — ускоряет работу" }
          ]
        },
        {
          "name": "Перечисление",
          "flags": [
            { "flag": "--dbs", "desc": "Перечислить доступные базы данных" },
            { "flag": "--tables", "desc": "Перечислить таблицы (в связке с -D)" },
            { "flag": "--columns", "desc": "Перечислить колонки (с -D и -T)" },
            { "flag": "--schema", "desc": "Выгрузить полную схему БД (базы/таблицы/колонки)" },
            { "flag": "--count", "desc": "Показать число записей в таблицах" },
            { "flag": "-D", "value": "dbname", "desc": "Указать базу данных" },
            { "flag": "-T", "value": "users", "desc": "Указать таблицу(ы)" },
            { "flag": "-C", "value": "user,pass", "desc": "Указать колонки" },
            { "flag": "--current-user", "desc": "Текущий пользователь БД" },
            { "flag": "--current-db", "desc": "Текущая база данных" },
            { "flag": "--is-dba", "desc": "Проверить, является ли пользователь DBA (админом БД)" },
            { "flag": "--users", "desc": "Перечислить пользователей СУБД" },
            { "flag": "--passwords", "desc": "Выгрузить хеши паролей пользователей" },
            { "flag": "--privileges", "desc": "Перечислить привилегии пользователей" },
            { "flag": "-b", "desc": "Получить баннер/версию СУБД" }
          ]
        },
        {
          "name": "Дамп данных",
          "flags": [
            { "flag": "--dump", "desc": "Выгрузить записи таблицы (с -D/-T/-C сужает объём)" },
            { "flag": "--dump-all", "desc": "Выгрузить все таблицы всех баз" },
            { "flag": "-a", "desc": "Достать всё, что возможно (--all)" },
            { "flag": "--search", "desc": "Искать базы/таблицы/колонки по имени" },
            { "flag": "--where", "value": "\"id>5\"", "desc": "Условие WHERE для выборочного дампа" },
            { "flag": "--start", "value": "1", "desc": "С какой записи начинать дамп" },
            { "flag": "--stop", "value": "100", "desc": "На какой записи остановить дамп" },
            { "flag": "--sql-query", "value": "\"SELECT ...\"", "desc": "Выполнить произвольный SQL-запрос" },
            { "flag": "--sql-shell", "desc": "Интерактивная SQL-консоль через инъекцию" }
          ]
        },
        {
          "name": "Обход WAF / Анонимность",
          "flags": [
            { "flag": "--tamper", "value": "space2comment", "desc": "Обфускация нагрузок tamper-скриптами для обхода WAF/фильтров" },
            { "flag": "--list-tampers", "desc": "Показать все доступные tamper-скрипты" },
            { "flag": "--random-agent", "desc": "Случайный User-Agent из встроенного словаря" },
            { "flag": "--skip-waf", "desc": "Пропустить определение WAF/IPS" },
            { "flag": "--proxy", "value": "http://127.0.0.1:8080", "desc": "Гнать трафик через прокси" },
            { "flag": "--tor", "desc": "Использовать сеть Tor для анонимности" },
            { "flag": "--check-tor", "desc": "Проверить, что трафик реально идёт через Tor" },
            { "flag": "--delay", "value": "1", "desc": "Задержка между запросами, секунд" },
            { "flag": "--timeout", "value": "30", "desc": "Таймаут соединения, секунд (по умолчанию 30)" }
          ]
        },
        {
          "name": "Доступ к ОС / ФС",
          "flags": [
            { "flag": "--os-shell", "desc": "Интерактивный шелл ОС на сервере (если позволяет СУБД/привилегии)" },
            { "flag": "--os-cmd", "value": "'whoami'", "desc": "Выполнить одну команду ОС" },
            { "flag": "--os-pwn", "desc": "OOB-шелл / Meterpreter / VNC через Metasploit" },
            { "flag": "--file-read", "value": "/etc/passwd", "desc": "Прочитать файл на сервере БД" },
            { "flag": "--file-write", "value": "shell.php", "desc": "Залить локальный файл на сервер" },
            { "flag": "--file-dest", "value": "/var/www/shell.php", "desc": "Путь назначения для записи файла" }
          ]
        },
        {
          "name": "Управление / Прочее",
          "flags": [
            { "flag": "--batch", "desc": "Не задавать вопросов — везде брать ответ по умолчанию (для автоматизации)" },
            { "flag": "--threads", "value": "5", "desc": "Число параллельных запросов (макс. 10) — ускоряет дамп" },
            { "flag": "--flush-session", "desc": "Сбросить сохранённую сессию и начать заново" },
            { "flag": "--fresh-queries", "desc": "Игнорировать кэш и выполнять запросы заново" },
            { "flag": "--crawl", "value": "2", "desc": "Краулить сайт на заданную глубину и тестировать найденное" },
            { "flag": "--forms", "desc": "Находить и тестировать HTML-формы на странице" },
            { "flag": "--parse-errors", "desc": "Показывать тексты ошибок СУБД из ответов" },
            { "flag": "-v", "value": "3", "desc": "Уровень детализации лога 0-6" }
          ]
        }
      ],
      "recipes": [
        { "cmd": "sqlmap -u {TARGET} --batch --dbs", "note": "Базовый прогон: найти инъекцию и перечислить базы" },
        { "cmd": "sqlmap -u {TARGET} --batch -D shop -T users --dump", "note": "Выгрузить таблицу users из базы shop" },
        { "cmd": "sqlmap -r req.txt --batch --level 3 --risk 2", "note": "POST/сложный запрос из файла с углублённым тестом" },
        { "cmd": "sqlmap -u {TARGET} --batch --tamper space2comment --random-agent", "note": "Обход WAF: обфускация + случайный User-Agent" },
        { "cmd": "sqlmap -u {TARGET} --batch --os-shell", "note": "Попытка получить шелл ОС при достаточных привилегиях" }
      ],
      "notes": "Начинай с малого --level/--risk и поднимай при необходимости — высокие значения создают много трафика, а --risk 3 (OR-инъекции) может изменить данные. --batch обязателен для скриптов."
    },
    {
      "title": "ghauri",
      "subcategory": "Быстрый детект SQL-инъекций",
      "purpose": "Лёгкая и быстрая альтернатива sqlmap для детекта и эксплуатации SQL-инъекций; часто берёт там, где sqlmap буксует на blind.",
      "install": "pipx install ghauri  # или git clone https://github.com/r0oth3x49/ghauri",
      "binary": "ghauri",
      "target": "-u {TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Цель",
          "flags": [
            { "flag": "-u", "value": "{TARGET}", "desc": "Целевой URL с параметром, напр. 'http://site/vuln.php?id=1'" },
            { "flag": "-r", "value": "req.txt", "desc": "Загрузить HTTP-запрос из файла" },
            { "flag": "-m", "value": "urls.txt", "desc": "Скан нескольких целей из файла" },
            { "flag": "--data", "value": "'id=1'", "desc": "POST-данные для тестирования" },
            { "flag": "--cookie", "value": "'sid=...'", "desc": "Значение заголовка Cookie" },
            { "flag": "-p", "value": "id", "desc": "Тестировать только указанные параметры" }
          ]
        },
        {
          "name": "Запрос",
          "flags": [
            { "flag": "-H", "value": "'X-Up: 1'", "desc": "Дополнительный HTTP-заголовок" },
            { "flag": "--random-agent", "desc": "Случайный User-Agent" },
            { "flag": "--proxy", "value": "http://127.0.0.1:8080", "desc": "Прокси для трафика" },
            { "flag": "--delay", "value": "1", "desc": "Задержка между запросами, секунд" },
            { "flag": "--timeout", "value": "30", "desc": "Таймаут соединения, секунд (по умолчанию 30)" },
            { "flag": "--threads", "value": "1", "desc": "Число параллельных запросов" }
          ]
        },
        {
          "name": "Детект / Техники",
          "flags": [
            { "flag": "--level", "value": "1", "desc": "Глубина проверки 1-3: выше — больше точек и нагрузок" },
            { "flag": "--technique", "value": "BEST", "desc": "Типы инъекций (по умолчанию BEST): B=boolean-blind, E=error-based, S=stacked queries, T=time-blind. Можно добавить U=union" },
            { "flag": "--dbms", "value": "MySQL", "desc": "Принудительно указать СУБД" },
            { "flag": "--time-sec", "value": "5", "desc": "Задержка для time-based blind, секунд" },
            { "flag": "--string", "value": "'OK'", "desc": "Строка, присутствующая в ответе при True" },
            { "flag": "--confirm", "desc": "Дополнительно перепроверять найденные нагрузки" }
          ]
        },
        {
          "name": "Перечисление / Дамп",
          "flags": [
            { "flag": "--dbs", "desc": "Перечислить базы данных" },
            { "flag": "--tables", "desc": "Перечислить таблицы (с -D)" },
            { "flag": "--columns", "desc": "Перечислить колонки (с -D и -T)" },
            { "flag": "--dump", "desc": "Выгрузить записи таблицы" },
            { "flag": "--count", "desc": "Число записей в таблицах" },
            { "flag": "-D", "value": "dbname", "desc": "Указать базу данных" },
            { "flag": "-T", "value": "users", "desc": "Указать таблицу(ы)" },
            { "flag": "-C", "value": "user,pass", "desc": "Указать колонки" },
            { "flag": "--current-user", "desc": "Текущий пользователь БД" },
            { "flag": "--current-db", "desc": "Текущая база данных" },
            { "flag": "--hostname", "desc": "Имя хоста сервера БД" },
            { "flag": "-b", "desc": "Получить баннер/версию СУБД (--banner)" },
            { "flag": "--start", "value": "1", "desc": "С какой записи начинать дамп" },
            { "flag": "--stop", "value": "100", "desc": "На какой записи остановить" }
          ]
        },
        {
          "name": "Управление",
          "flags": [
            { "flag": "--batch", "desc": "Не задавать вопросов — брать значения по умолчанию" },
            { "flag": "--flush-session", "desc": "Сбросить сохранённую сессию" },
            { "flag": "--fresh-queries", "desc": "Игнорировать кэш результатов" },
            { "flag": "--sql-shell", "desc": "Интерактивная SQL-консоль (экспериментально)" },
            { "flag": "-v", "value": "1", "desc": "Уровень детализации 1-5" }
          ]
        }
      ],
      "recipes": [
        { "cmd": "ghauri -u {TARGET} --batch --dbs", "note": "Найти инъекцию и перечислить базы" },
        { "cmd": "ghauri -u {TARGET} --batch -D shop -T users --dump", "note": "Выгрузить таблицу users" },
        { "cmd": "ghauri -r req.txt --batch --level 2", "note": "POST/сложный запрос из файла с углублённым тестом" }
      ],
      "notes": "Синтаксис почти повторяет sqlmap, поэтому рецепты переносимы. Хорош для blind-инъекций и когда нужна скорость."
    },
    {
      "title": "wpscan",
      "subcategory": "Сканер безопасности WordPress",
      "purpose": "Специализированный сканер WordPress: версии ядра/плагинов/тем, известные уязвимости, перечисление пользователей и брутфорс логина.",
      "install": "gem install wpscan  # или docker run wpscanteam/wpscan",
      "binary": "wpscan",
      "target": "--url {TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Цель",
          "flags": [
            { "flag": "--url", "value": "{TARGET}", "desc": "Адрес целевого сайта WordPress" },
            { "flag": "--wp-content-dir", "value": "wp-content", "desc": "Нестандартный путь к каталогу wp-content" },
            { "flag": "--wp-plugins-dir", "value": "wp-content/plugins", "desc": "Нестандартный путь к каталогу плагинов" }
          ]
        },
        {
          "name": "Перечисление",
          "flags": [
