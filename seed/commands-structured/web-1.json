{
  "category": "WEB",
  "catOrder": 2,
  "tools": [
    {
      "title": "nmap",
      "subcategory": "сканер портов и сервисов",
      "purpose": "Сканер сети: находит живые хосты, открытые порты, версии сервисов и ОС, запускает NSE-скрипты. Первый шаг разведки почти на любой машине.",
      "install": "sudo apt install nmap",
      "binary": "nmap",
      "target": "{TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Обнаружение хостов",
          "flags": [
            { "flag": "-sn", "desc": "Только пинг-скан (host discovery) без сканирования портов — найти живые хосты в подсети." },
            { "flag": "-Pn", "desc": "Пропустить обнаружение хостов, считать цель живой. Нужен, когда хост блокирует ICMP (типично для HTB)." },
            { "flag": "-sL", "desc": "List Scan: только перечислить и резолвить цели, не отправляя пакеты." },
            { "flag": "-n", "desc": "Не делать обратный DNS-резолв (ускоряет скан)." },
            { "flag": "-R", "desc": "Всегда делать DNS-резолв, даже для недоступных хостов." },
            { "flag": "-PS", "value": "22,80,443", "desc": "TCP SYN ping по указанным портам для обнаружения хоста." },
            { "flag": "-PA", "value": "80", "desc": "TCP ACK ping по указанным портам." },
            { "flag": "--dns-servers", "value": "1.1.1.1", "desc": "Использовать свои DNS-серверы для резолва." }
          ]
        },
        {
          "name": "Техника скана",
          "flags": [
            { "flag": "-sS", "desc": "TCP SYN (half-open / stealth) скан. Дефолт при наличии root, быстрый и менее заметный." },
            { "flag": "-sT", "desc": "TCP Connect-скан (полное соединение). Дефолт без root-прав." },
            { "flag": "-sU", "desc": "UDP-скан. Медленный — обычно сочетают с --top-ports." },
            { "flag": "-sA", "desc": "TCP ACK-скан — маппинг правил фаервола (фильтруется/не фильтруется)." },
            { "flag": "-sN", "desc": "TCP Null-скан (без флагов) — обход простых фильтров." },
            { "flag": "-sF", "desc": "TCP FIN-скан — обход простых фильтров." },
            { "flag": "-sX", "desc": "TCP Xmas-скан (FIN+PSH+URG)." },
            { "flag": "-sO", "desc": "Скан IP-протоколов (какие протоколы поддерживает хост)." }
          ]
        },
        {
          "name": "Порты",
          "flags": [
            { "flag": "-p", "value": "80,443", "desc": "Сканировать только указанные порты. Диапазоны (1-1000) и префиксы T:/U: поддерживаются." },
            { "flag": "-p-", "desc": "Сканировать все 65535 портов." },
            { "flag": "--top-ports", "value": "1000", "desc": "Сканировать N самых распространённых портов." },
            { "flag": "-F", "desc": "Быстрый режим — только топ-100 портов." },
            { "flag": "--exclude-ports", "value": "9100", "desc": "Исключить указанные порты из скана." },
            { "flag": "-r", "desc": "Сканировать порты по порядку, не рандомизировать." }
          ]
        },
        {
          "name": "Версии, ОС, скрипты",
          "flags": [
            { "flag": "-sV", "desc": "Определение версий сервисов на открытых портах." },
            { "flag": "--version-intensity", "value": "9", "desc": "Интенсивность version-скана: 0 (лёгкий) … 9 (все пробы)." },
            { "flag": "--version-all", "desc": "Пробовать все пробы определения версии (= intensity 9)." },
            { "flag": "-O", "desc": "Определение операционной системы по сетевым отпечаткам." },
            { "flag": "--osscan-guess", "desc": "Агрессивнее угадывать ОС, когда точного совпадения нет." },
            { "flag": "-sC", "desc": "Запустить набор default NSE-скриптов (эквивалент --script=default)." },
            { "flag": "--script", "value": "vuln", "desc": "Запустить NSE-скрипты по имени/категории/папке (default, safe, vuln, auth, brute, discovery)." },
            { "flag": "--script-args", "value": "user=admin", "desc": "Передать аргументы NSE-скриптам (n1=v1,n2=v2)." },
            { "flag": "-A", "desc": "Агрессивный режим: включает -O, -sV, -sC и --traceroute разом." }
          ]
        },
        {
          "name": "Тайминг и производительность",
          "flags": [
            { "flag": "-T4", "desc": "Шаблон тайминга 0..5 (paranoid..insane). T3 — дефолт, T4 — быстро для лаб/CTF." },
            { "flag": "--min-rate", "value": "1000", "desc": "Не медленнее N пакетов в секунду — ускоряет полный скан портов." },
            { "flag": "--max-rate", "value": "5000", "desc": "Не быстрее N пакетов в секунду — щадящий режим под WAF/IDS." },
            { "flag": "--max-retries", "value": "2", "desc": "Лимит ретрансмиссий проб на порт." },
            { "flag": "--host-timeout", "value": "30m", "desc": "Бросить хост, если он не доскан за это время (суффиксы ms/s/m/h)." },
            { "flag": "--scan-delay", "value": "1s", "desc": "Минимальная задержка между пробами к хосту (обход rate-limit)." }
          ]
        },
        {
          "name": "Обход фаервола / IDS",
          "flags": [
            { "flag": "-f", "desc": "Фрагментировать пакеты на мелкие IP-фрагменты (-ff — сильнее)." },
            { "flag": "--mtu", "value": "16", "desc": "Фрагментировать с заданным MTU (кратно 8)." },
            { "flag": "-D", "value": "RND:10", "desc": "Маскировать скан декоями (decoy1,decoy2,ME,...)." },
            { "flag": "-S", "value": "{LHOST}", "desc": "Подделать IP источника." },
            { "flag": "-g", "value": "53", "desc": "Использовать заданный исходящий порт (обход фильтров по source-port)." },
            { "flag": "--spoof-mac", "value": "0", "desc": "Подделать MAC (0 = случайный, либо префикс/вендор)." },
            { "flag": "-e", "value": "tun0", "desc": "Использовать указанный сетевой интерфейс." }
          ]
        },
        {
          "name": "Вывод",
          "flags": [
            { "flag": "-oA", "value": "scan", "desc": "Сохранить все три формата сразу: scan.nmap, scan.xml, scan.gnmap." },
            { "flag": "-oN", "value": "scan.txt", "desc": "Сохранить обычный (человекочитаемый) вывод в файл." },
            { "flag": "-oX", "value": "scan.xml", "desc": "Сохранить вывод в XML." },
            { "flag": "-oG", "value": "scan.gnmap", "desc": "Сохранить grepable-вывод (удобно для grep/awk)." },
            { "flag": "-v", "desc": "Подробный вывод (-vv ещё подробнее)." },
            { "flag": "--reason", "desc": "Показать причину, почему порт в данном состоянии." },
            { "flag": "--open", "desc": "Показывать только открытые (и open|filtered) порты." },
            { "flag": "--packet-trace", "desc": "Показать все отправленные/принятые пакеты (отладка)." }
          ]
        },
        {
          "name": "Цели и прочее",
          "flags": [
            { "flag": "-iL", "value": "targets.txt", "desc": "Брать цели из файла (по одной на строку)." },
            { "flag": "-iR", "value": "100", "desc": "Выбрать N случайных целей (0 = бесконечно)." },
            { "flag": "--exclude", "value": "{TARGET}", "desc": "Исключить указанные хосты/сети из скана." },
            { "flag": "-6", "desc": "Включить сканирование IPv6." },
            { "flag": "--resume", "value": "scan.txt", "desc": "Возобновить прерванный скан из normal/grepable-вывода." }
          ]
        }
      ],
      "recipes": [
        { "cmd": "nmap -sC -sV -oA scan {TARGET}", "note": "Стандартный первый скан: default-скрипты + версии, сохранить все форматы." },
        { "cmd": "nmap -p- --min-rate 10000 -oA allports {TARGET}", "note": "Быстрый полный свип всех TCP-портов; затем точечно доскан найденных." },
        { "cmd": "nmap -p 22,80,443 -sC -sV -oA deep {TARGET}", "note": "Глубокий скан только по открытым портам, найденным на этапе свипа." },
        { "cmd": "nmap -sU --top-ports 100 {TARGET}", "note": "UDP-скан топ-100 портов (UDP медленный — ограничиваем объём)." },
        { "cmd": "nmap --script vuln {TARGET}", "note": "Прогон NSE-скриптов категории vuln по известным уязвимостям." },
        { "cmd": "sudo nmap -sS -Pn -T4 {TARGET}", "note": "Стелс-SYN со скипом host-discovery, когда ICMP блокируется (HTB)." }
      ],
      "notes": "Цель позиционна (без флага), принимает hostname/IP/CIDR (10.0.0.0/24) и диапазоны (10.0.0.1-50). -sS и -O требуют root. По умолчанию сканируются топ-1000 портов. -sn — современное имя старого -sP."
    },
    {
      "title": "ffuf",
      "subcategory": "веб-фаззер по ключу FUZZ",
      "purpose": "Быстрый веб-фаззер на Go: подставляет слова из словаря на место ключа FUZZ в URL, заголовке, теле или куках. Брут директорий/файлов, параметров, vhost'ов, перебор значений.",
      "install": "go install github.com/ffuf/ffuf/v2@latest",
      "binary": "ffuf",
      "target": "-u {TARGET}/FUZZ",
      "modes": [],
      "groups": [
        {
          "name": "Ввод и словари",
          "flags": [
            { "flag": "-w", "value": "wordlist.txt", "desc": "Словарь; можно привязать ключ: wordlist.txt:KEY. Повторяемый для нескольких словарей." },
            { "flag": "-mode", "value": "clusterbomb", "desc": "Режим мультисловаря: clusterbomb (все комбинации), pitchfork (по индексам), sniper (по одной позиции)." },
            { "flag": "-e", "value": ".php,.bak,.html", "desc": "Список расширений, дописываемых к ключу FUZZ (через запятую)." },
            { "flag": "-request", "value": "req.txt", "desc": "Сырой HTTP-запрос из файла (например, сохранённый из Burp) с FUZZ внутри." },
            { "flag": "-request-proto", "value": "https", "desc": "Протокол для сырого запроса (http/https)." },
            { "flag": "-ic", "desc": "Игнорировать комментарии в словаре (строки с #)." },
            { "flag": "-D", "desc": "Режим совместимости со словарями dirsearch (используется с -e)." }
          ]
        },
        {
          "name": "HTTP-запрос",
          "flags": [
            { "flag": "-u", "value": "{TARGET}/FUZZ", "desc": "Целевой URL. Ключ FUZZ ставится туда, где нужно перебирать." },
            { "flag": "-X", "value": "POST", "desc": "HTTP-метод запроса." },
            { "flag": "-H", "value": "Header: value", "desc": "Заголовок. Повторяемый. Для vhost-фаззинга: -H 'Host: FUZZ.target'." },
            { "flag": "-d", "value": "user=FUZZ", "desc": "Тело POST-запроса (можно с FUZZ)." },
            { "flag": "-b", "value": "name=value", "desc": "Куки в формате 'n1=v1; n2=v2'." },
            { "flag": "-r", "desc": "Следовать редиректам." },
            { "flag": "-x", "value": "http://127.0.0.1:8080", "desc": "Прокси для всех запросов (HTTP/SOCKS5)." },
            { "flag": "-replay-proxy", "value": "http://127.0.0.1:8080", "desc": "Переотправлять только совпавшие запросы через прокси (в Burp)." },
            { "flag": "-recursion", "desc": "Рекурсивный скан (URL должен заканчиваться на FUZZ)." },
            { "flag": "-recursion-depth", "value": "2", "desc": "Максимальная глубина рекурсии." },
            { "flag": "-timeout", "value": "10", "desc": "Таймаут HTTP-запроса в секундах." },
            { "flag": "-http2", "desc": "Использовать HTTP/2." }
          ]
        },
        {
          "name": "Матчеры (что показывать)",
          "flags": [
            { "flag": "-mc", "value": "200,301,302", "desc": "Показывать только эти коды ответа (или all). Дефолт: 200-299,301,302,307,401,403,405,500." },
            { "flag": "-ms", "value": "1024", "desc": "Показывать по размеру ответа (байты)." },
            { "flag": "-ml", "value": "10", "desc": "Показывать по числу строк в ответе." },
            { "flag": "-mw", "value": "50", "desc": "Показывать по числу слов в ответе." },
            { "flag": "-mr", "value": "regexp", "desc": "Показывать по совпадению регекспа в ответе." },
            { "flag": "-mt", "value": ">100", "desc": "Показывать по времени до первого байта (мс)." },
            { "flag": "-mmode", "value": "or", "desc": "Логика матчеров: and / or (дефолт or)." }
          ]
        },
        {
          "name": "Фильтры (что скрывать)",
          "flags": [
            { "flag": "-fc", "value": "404", "desc": "Скрыть эти коды ответа (через запятую, поддержка диапазонов)." },
            { "flag": "-fs", "value": "1024", "desc": "Скрыть по размеру ответа (байты) — классика против шумных 404." },
            { "flag": "-fl", "value": "10", "desc": "Скрыть по числу строк." },
            { "flag": "-fw", "value": "50", "desc": "Скрыть по числу слов." },
            { "flag": "-fr", "value": "regexp", "desc": "Скрыть по совпадению регекспа." },
            { "flag": "-ft", "value": "<100", "desc": "Скрыть по времени до первого байта." },
            { "flag": "-fmode", "value": "or", "desc": "Логика фильтров: and / or (дефолт or)." },
            { "flag": "-ac", "desc": "Автокалибровка фильтров (сама определяет шумный baseline)." }
          ]
        },
        {
          "name": "Общие",
          "flags": [
            { "flag": "-t", "value": "40", "desc": "Число потоков (дефолт 40)." },
            { "flag": "-rate", "value": "100", "desc": "Лимит запросов в секунду (0 = без лимита)." },
            { "flag": "-p", "value": "0.1", "desc": "Задержка между запросами: фикс '0.1' или диапазон '0.1-2.0'." },
            { "flag": "-maxtime", "value": "300", "desc": "Максимальное время работы всего процесса (сек)." },
            { "flag": "-s", "desc": "Тихий режим — только результаты, без баннера и прогресса." },
            { "flag": "-c", "desc": "Цветной вывод." },
            { "flag": "-v", "desc": "Подробный вывод — полный URL и redirect-локация." },
            { "flag": "-sf", "desc": "Остановиться, если >95% ответов — 403 Forbidden." }
          ]
        },
        {
          "name": "Вывод",
          "flags": [
            { "flag": "-o", "value": "out.json", "desc": "Записать результаты в файл." },
            { "flag": "-of", "value": "json", "desc": "Формат файла: json, ejson, html, md, csv, ecsv, all." },
            { "flag": "-od", "value": "responses/", "desc": "Папка для сохранения тел совпавших ответов." },
            { "flag": "-or", "desc": "Не создавать файл вывода, если результатов нет." }
          ]
        }
      ],
      "recipes": [
        { "cmd": "ffuf -u {TARGET}/FUZZ -w wordlist.txt -mc all -fs 0", "note": "Брут директорий/файлов: показать всё и отфильтровать шум по размеру." },
        { "cmd": "ffuf -u {TARGET}/FUZZ -w wordlist.txt -e .php,.txt,.bak -ac", "note": "Брут файлов с расширениями и автокалибровкой фильтров." },
        { "cmd": "ffuf -u {TARGET} -H 'Host: FUZZ.target.htb' -w subs.txt -fs 0", "note": "Перебор виртуальных хостов; отфильтровать размер дефолтного ответа." },
        { "cmd": "ffuf -u {TARGET}/FUZZ -w wordlist.txt -recursion -recursion-depth 2 -e .php", "note": "Рекурсивный брут с дописыванием расширения (URL кончается на FUZZ)." },
        { "cmd": "ffuf -request req.txt -request-proto https -w params.txt -fc 404", "note": "Фаззинг по сырому запросу из Burp с FUZZ внутри файла." }
      ],
      "notes": "Ключ FUZZ подставляется в любую часть запроса. Для нескольких словарей используй -w файл:KEY и -mode. Дефолтный матчер кодов — 200-299,301,302,307,401,403,405,500. Типичный воркфлоу: -mc all + фильтр по размеру/словам/строкам."
    },
    {
      "title": "feroxbuster",
      "subcategory": "рекурсивный контент-брутфорс",
      "purpose": "Быстрый рекурсивный сканер контента на Rust. Брутит директории и файлы, по умолчанию извлекает ссылки из ответов и автоматически уходит в рекурсию. Удобные авто-режимы (--smart/--thorough).",
      "install": "curl -sL https://raw.githubusercontent.com/epi052/feroxbuster/main/install-nix.sh | bash",
      "binary": "feroxbuster",
      "target": "-u {TARGET}",
      "modes": [],
      "groups": [
        {
          "name": "Цель и словарь",
          "flags": [
            { "flag": "-u", "value": "{TARGET}", "desc": "Целевой URL (короткий/длинный: -u/--url). Повторяемый." },
            { "flag": "-w", "value": "wordlist.txt", "desc": "Путь или URL словаря (-w/--wordlist)." },
            { "flag": "--stdin", "desc": "Читать список URL из STDIN." },
            { "flag": "--resume-from", "value": "ferox.state", "desc": "Возобновить незавершённый скан из state-файла." },
            { "flag": "--request-file", "value": "req.txt", "desc": "Сырой HTTP-запрос как шаблон для всех запросов." }
          ]
        },
        {
          "name": "Авто-режимы",
          "flags": [
            { "flag": "--burp", "desc": "Прокси на http://127.0.0.1:8080 + отключить проверку TLS (одной командой в Burp)." },
            { "flag": "--burp-replay", "desc": "Слать в Burp только нефильтрованные (найденные) запросы." },
            { "flag": "--smart", "desc": "Включает --auto-tune, --collect-words и --collect-backups." },
            { "flag": "--thorough", "desc": "Как --smart, плюс --collect-extensions и --scan-dir-listings (режим «по максимуму»)." },
            { "flag": "--data-urlencoded", "value": "user=admin", "desc": "POST с Content-Type form-urlencoded и этим телом (поддержка @file)." }
          ]
        },
        {
          "name": "Запрос",
          "flags": [
            { "flag": "-x", "value": "php,html,txt", "desc": "Расширения для поиска (-x/--extensions), через запятую или пробел, без точки. @file тоже." },
            { "flag": "-H", "value": "Header: value", "desc": "HTTP-заголовки (-H/--headers). Повторяемый." },
            { "flag": "-b", "value": "name=value", "desc": "Куки (-b/--cookies)." },
            { "flag": "-Q", "value": "token=stuff", "desc": "Query-параметры URL (-Q/--query)." },
            { "flag": "-m", "value": "GET", "desc": "HTTP-метод(ы) (-m/--methods), дефолт GET." },
            { "flag": "--data", "value": "body", "desc": "Тело запроса (поддержка @file для чтения из файла)." },
            { "flag": "-a", "value": "Mozilla/5.0", "desc": "User-Agent (-a/--user-agent)." },
            { "flag": "-A", "desc": "Случайный User-Agent (-A/--random-agent)." },
            { "flag": "-f", "desc": "Дописывать / к каждому URL (-f/--add-slash)." }
          ]
        },
        {
          "name": "Фильтры ответов",
          "flags": [
            { "flag": "-s", "value": "200,301,302", "desc": "Белый список кодов (-s/--status-codes): показывать только эти. Дефолт — все." },
            { "flag": "-C", "value": "404,403", "desc": "Чёрный список кодов (-C/--filter-status): скрыть эти." },
            { "flag": "-S", "value": "5120", "desc": "Скрыть по размеру ответа (-S/--filter-size)." },
            { "flag": "-W", "value": "312", "desc": "Скрыть по числу слов (-W/--filter-words)." },
            { "flag": "-N", "value": "20", "desc": "Скрыть по числу строк (-N/--filter-lines)." },
            { "flag": "-X", "value": "regexp", "desc": "Скрыть по регекспу в теле/заголовках (-X/--filter-regex)." },
            { "flag": "--filter-similar-to", "value": "{TARGET}/soft404", "desc": "Скрыть страницы, похожие на указанную (борьба с soft-404)." },
            { "flag": "-D", "desc": "Не автофильтровать wildcard-ответы (-D/--dont-filter)." }
          ]
        },
        {
          "name": "Рекурсия и скан",
          "flags": [
