            { "flag": "--alter-shell", "value": "Python", "desc": "Use an alternative shell (e.g. Python)" },
            { "flag": "--all", "desc": "Gather all available system information" },
            { "flag": "--current-user", "desc": "Current OS user" },
            { "flag": "--hostname", "desc": "System hostname" },
            { "flag": "--is-root", "desc": "Check whether the user is root (Unix)" },
            { "flag": "--is-admin", "desc": "Check administrator privileges (Windows)" },
            { "flag": "--sys-info", "desc": "OS and system information" },
            { "flag": "--file-read", "value": "/etc/passwd", "desc": "Read a file from the target" },
            { "flag": "--file-write", "value": "shell.sh", "desc": "Write a local file to the target" }
          ]
        },
        {
          "name": "WAF bypass / Control",
          "flags": [
            { "flag": "--tamper", "value": "space2ifs", "desc": "Obfuscate payloads with tamper scripts to bypass filters/WAF" },
            { "flag": "--list-tampers", "desc": "Show available tamper scripts" },
            { "flag": "--skip-waf", "desc": "Skip WAF/IPS detection" },
            { "flag": "--shellshock", "desc": "Test for Shellshock (CVE-2014-6271) in CGI" },
            { "flag": "--batch", "desc": "Ask no questions - use the default answers" },
            { "flag": "--delay", "value": "0", "desc": "Delay between requests, seconds" },
            { "flag": "--flush-session", "desc": "Reset the saved session" }
          ]
        }
      ],
      "recipes": [
        { "cmd": "commix -u {TARGET} --batch", "note": "Basic command injection detection" },
        { "cmd": "commix -u {TARGET} --batch --os-shell", "note": "On success - an interactive OS shell" },
        { "cmd": "commix -r req.txt --batch --level 2", "note": "Request from a file with Cookie testing" },
        { "cmd": "commix -u {TARGET} --batch --os-cmd 'id'", "note": "Run a single command without interaction" }
      ],
      "notes": "Once an entry point is found - try --os-shell right away. --technique narrows the injection types; classic gives instant output, time/file-based work blind."
    },
