            { "flag": "--technique", "value": "cetf", "desc": "Injection techniques: c=classic (output right in the response), e=eval-based (dynamic eval), t=time-based blind, f=file-based (write to a file and read)" },
            { "flag": "--skip-technique", "value": "t", "desc": "Exclude the specified techniques" },
